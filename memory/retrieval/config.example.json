{
  "_comment": "示例：让检索指向项目本地的运行时记忆 store（而非 Obsidian）。grader 把每通对话的 issue 沉淀成 *.md 后，agent 启动前可 memory_search 拉相关历史教训。",
  "store_dir": "./memory/store",
  "db_path": "./memory/.memory_index.db",
  "exclude_files": ["index.md", "log.md", "README.md"],
  "frontmatter_fields": {
    "title": "title",
    "summary": "summary",
    "tags": "tags",
    "type": "type",
    "updated": "updated",
    "created": "created",
    "provenance": "provenance",
    "confidence": "confidence"
  },
  "conf_penalty": 0.5,
  "fts_weights": {"title": 10.0, "summary": 6.0, "tags": 4.0, "body": 1.0},
  "like_weights": {"title": 3, "summary": 2, "tags": 2, "body": 1},
  "rrf_k": 60,
  "half_life_days": 30,
  "recency_boost": 0.5,
  "no_date_weight": 0.3,
  "output_format": "json"
}
